<configuration>
    <conversionRule conversionWord="colorLevel"
                    converterClass="eu.europa.ted.efx.cli.ColorLevelConverter" />

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%colorLevel %msg%n</pattern>
        </encoder>
    </appender>

    <root level="WARN">
        <appender-ref ref="STDOUT" />
    </root>

    <logger name="eu.europa.ted.efx.cli" level="INFO" />
</configuration>
